{
    "name":  "team-agent-mvp-server",
    "version":  "1.0.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "tsx watch src/index.ts",
                    "build":  "tsc -p tsconfig.json",
                    "test": "node --test --import tsx test/all.test.ts",
                    "start":  "node dist/src/index.js",
                    "prisma:generate":  "prisma generate",
                    "prisma:migrate":  "prisma migrate deploy",
                    "prisma:migrate:dev": "prisma migrate dev",
                    "prisma:seed":  "tsx prisma/seed.ts",
                    "import:legacy-sqlite": "tsx scripts/import-legacy-sqlite.ts",
                    "bootstrap": "tsx scripts/bootstrap.ts",
                    "context:apply": "tsx scripts/apply-domain-context.ts",
                    "sync:agno-catalog": "tsx scripts/sync-agno-catalog.ts"
                },
    "dependencies":  {
                         "@prisma/client":  "^6.17.1",
                         "bcrypt":  "^6.0.0",
                         "cookie-parser":  "^1.4.7",
                         "cors":  "^2.8.5",
                         "express":  "^5.1.0",
                         "express-rate-limit":  "^8.1.0",
                         "express-session":  "^1.18.2",
                         "helmet":  "^8.1.0",
                         "nanoid":  "^5.1.6",
                         "pino":  "^10.1.0",
                         "pino-http":  "^11.0.0",
                         "yaml":  "^2.8.1",
                         "zod":  "^4.1.11"
                     },
    "devDependencies":  {
                            "@types/bcrypt":  "^6.0.0",
                            "@types/cookie-parser":  "^1.4.10",
                            "@types/cors":  "^2.8.19",
                            "@types/express":  "^5.0.6",
                            "@types/express-session":  "^1.18.2",
                            "@types/node":  "^25.3.0",
                            "prisma":  "^6.17.1",
                            "tsx":  "^4.21.0",
                            "typescript":  "^5.9.3"
                        }
}
